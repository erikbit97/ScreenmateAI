<Window x:Class="ChatGPTWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Screenmate AI"
        Height="760"
        Width="1280"
        MinHeight="650"
        MinWidth="1050"
        WindowStartupLocation="CenterScreen"
        Background="#0F172A">

    <Window.Resources>

        <Style x:Key="ModernButton" TargetType="Button">

            <Setter Property="Height" Value="42"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="BorderBrush" Value="#2563EB"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="BorderThickness" Value="0"/>

            <Setter Property="Template">
                <Setter.Value>

                    <ControlTemplate TargetType="Button">

                        <Border Background="{TemplateBinding Background}"
                        CornerRadius="10">

                            <ContentPresenter HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>

                        </Border>

                    </ControlTemplate>

                </Setter.Value>
            </Setter>

        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource ModernButton}">
            <Setter Property="Background" Value="#334155"/>
            <Setter Property="BorderBrush" Value="#475569"/>
        </Style>

        <Style x:Key="SwitchToggleStyle" TargetType="ToggleButton">
            <Setter Property="Width" Value="42"/>
            <Setter Property="Height" Value="22"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Grid>
                            <Border x:Name="SwitchBackground"
                                    CornerRadius="11"
                                    Background="#64748B"/>
                            <Ellipse x:Name="SwitchKnob"
                                     Width="16"
                                     Height="16"
                                     Fill="White"
                                     HorizontalAlignment="Left"
                                     Margin="3"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="SwitchBackground" Property="Background" Value="#10A37F"/>
                                <Setter TargetName="SwitchKnob" Property="HorizontalAlignment" Value="Right"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
       

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Top Bar -->
        <Border Grid.Row="0"
                Background="#111827"
                BorderBrush="#1F2937"
                BorderThickness="0,0,0,1">
            <DockPanel Margin="18,0">

                <TextBlock Text="Screenmate AI"
                           Foreground="White"
                           FontSize="20"
                           FontWeight="Bold"
                           VerticalAlignment="Center"
                           DockPanel.Dock="Left"/>

                <StackPanel Orientation="Horizontal"
                            DockPanel.Dock="Right"
                            VerticalAlignment="Center">

                    <TextBlock Text="Just Chatting Mode"
                               Foreground="#CBD5E1"
                               VerticalAlignment="Center"
                               Margin="0,0,10,0"/>

                    <ToggleButton x:Name="JustChattingToggle"
                                  Style="{StaticResource SwitchToggleStyle}"
                                  Checked="JustChatting_Checked"
                                  Unchecked="JustChatting_Unchecked"/>
                    <Border Background="#1E293B"
        BorderBrush="#475569"
        BorderThickness="1"
        CornerRadius="8">

                        <ComboBox x:Name="screens"
              Background="Transparent"
              BorderThickness="0"
              Padding="5"
              Width="180"
              Height="28"/>
                    </Border>

                </StackPanel>

            </DockPanel>
        </Border>

        <!-- Main Layout -->
        <Grid Grid.Row="1" Margin="14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="240"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Screenshots -->
            <Border Grid.Column="0"
                    Background="#111827"
                    CornerRadius="14"
                    Padding="14"
                    Margin="0,0,12,0"
                    BorderBrush="#1F2937"
                    BorderThickness="1">

                <StackPanel>
                    <TextBlock Text="Gesendete Bilder"
                               Foreground="White"
                               FontSize="16"
                               FontWeight="Bold"
                               Margin="0,0,0,4"/>

                    <TextBlock Text="Diese Screenshots wurden zuletzt an die KI gesendet."
                               Foreground="#94A3B8"
                               TextWrapping="Wrap"
                               FontSize="12"
                               Margin="0,0,0,14"/>

                    <StackPanel x:Name="SentScreenshotsPanel"/>
                </StackPanel>
            </Border>

            <!-- Center: Chat -->
            <Border Grid.Column="1"
                    Background="#111827"
                    CornerRadius="14"
                    BorderBrush="#1E293B"
                    BorderThickness="1"
                    Margin="0,0,12,0">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <ScrollViewer Grid.Row="0"
                                  VerticalScrollBarVisibility="Auto"
                                  Padding="18" >
                        <StackPanel x:Name="ChatPanel" />
                    </ScrollViewer>

                    <Border Grid.Row="1"
                            Background="#111827"
                            Padding="14"
                            BorderBrush="#0F172A"
                            BorderThickness="0,1,0,0"
                            CornerRadius="0,0,14,14">

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="120"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                Background="#1E293B"
                                BorderBrush="#334155"
                                BorderThickness="1"
                                CornerRadius="10"
                                Height="42">

                                <TextBox x:Name="InputTextBox"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Foreground="White"
                                    CaretBrush="White"
                                    FontSize="14"
                                    Padding="10"
                                    VerticalContentAlignment="Center"/>

                            </Border>

                            <Button x:Name="SendButton"
                                    Grid.Column="2"
                                    Content="Senden"
                                    Style="{StaticResource ModernButton}"
                                    Click="SendButton_Click" />

                            <Button x:Name="LiveToggleButton"
                                    Grid.Column="4"
                                    Content="Live Start"
                                    Style="{StaticResource SecondaryButton}"
                                    Click="LiveToggleButton_Click"/>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <!-- Right: Conversations -->
            <Border Grid.Column="2"
                    Background="#111827"
                    CornerRadius="14"
                    Padding="14"
                    BorderBrush="#1F2937"
                    BorderThickness="1">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="Chats"
                               Foreground="White"
                               FontSize="16"
                               FontWeight="Bold"
                               Margin="0,0,0,12"/>

                    <Button Grid.Row="1"
                            Content="Neuer Chat"
                            Style="{StaticResource SecondaryButton}"
                            Margin="0,0,0,12"
                            Click="NewChatButton_Click"/>

                    <ListBox Grid.Row="2"
                             x:Name="ConversationListBox"
                             Background="#0F172A"
                             Foreground="White"
                             BorderBrush="#334155"
                             SelectionChanged="ConversationListBox_SelectionChanged">

                        <ListBox.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Umbenennen"
                                          Click="RenameConversation_Click"/>
                                <MenuItem Header="Löschen"
                                          Click="DeleteConversation_Click"/>
                            </ContextMenu>
                        </ListBox.ContextMenu>

                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="4">
                                    <TextBlock Text="{Binding Title}"
                                               Foreground="White"
                                               Padding="8"
                                               TextTrimming="CharacterEllipsis">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Visible"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsRenaming}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                    <TextBox Text="{Binding Title}"
                                             KeyDown="RenameInlineTextBox_KeyDown"
                                             Padding="8"
                                             Background="#1E293B"
                                             Foreground="White"
                                             BorderBrush="#475569">
                                        <TextBox.Style>
                                            <Style TargetType="TextBox">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsRenaming}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBox.Style>
                                    </TextBox>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

        </Grid>
    </Grid>
</Window>