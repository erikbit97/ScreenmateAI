<Window x:Class="ChatGPTWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ChatGPT WPF" Height="500" Width="950">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="200"/>
        </Grid.ColumnDefinitions>
        <!-- Rechte SEITE: Chat Themen -->
        <Border Grid.Column="2"
        Background="#F3F3F3"
        Padding="10"
        Margin="5">

            <StackPanel>
                <TextBlock Text="Chats"
                   FontWeight="Bold"
                   Margin="0,0,0,10"/>

                <Button Content="Neuer Chat"
                Height="35"
                Margin="0,0,0,10"
                Click="NewChatButton_Click"/>

                <ListBox x:Name="ConversationListBox"
         SelectionChanged="ConversationListBox_SelectionChanged">
                    <ListBox.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="Umbenennen"
                      Click="RenameConversation_Click"/>

                            <MenuItem Header="Löschen"
                      Click="DeleteConversation_Click"/>
                        </ContextMenu>
                    </ListBox.ContextMenu>
                    <ListBox.ItemTemplate>

                        <DataTemplate>

                            <Grid Margin="0,2">

                                <!-- NORMALER TITEL -->
                                <TextBlock Text="{Binding Title}"
                           VerticalAlignment="Center">

                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">

                                            <Setter Property="Visibility"
                                    Value="Visible"/>

                                            <Style.Triggers>

                                                <DataTrigger Binding="{Binding IsRenaming}"
                                             Value="True">

                                                    <Setter Property="Visibility"
                                            Value="Collapsed"/>

                                                </DataTrigger>

                                            </Style.Triggers>

                                        </Style>
                                    </TextBlock.Style>

                                </TextBlock>

                                <!-- TEXTBOX -->
                                <TextBox Text="{Binding Title}"
                         KeyDown="RenameInlineTextBox_KeyDown">

                                    <TextBox.Style>
                                        <Style TargetType="TextBox">

                                            <Setter Property="Visibility"
                                    Value="Collapsed"/>

                                            <Style.Triggers>

                                                <DataTrigger Binding="{Binding IsRenaming}"
                                             Value="True">

                                                    <Setter Property="Visibility"
                                            Value="Visible"/>

                                                </DataTrigger>

                                            </Style.Triggers>

                                        </Style>
                                    </TextBox.Style>

                                </TextBox>

                            </Grid>

                        </DataTemplate>

                    </ListBox.ItemTemplate>

                </ListBox>
               

            </StackPanel>
        </Border>
        <!-- LINKE SEITE: gesendete Screenshots -->
        <Border Grid.Column="0"
            Background="#1E1E1E"
            Padding="10"
            Margin="5">

            <StackPanel>
                <TextBlock Text="Aktuell gesendete Bilder"
                       Foreground="White"
                       FontWeight="Bold"
                       Margin="0,0,0,10"/>

                <StackPanel x:Name="SentScreenshotsPanel"/>
            </StackPanel>
        </Border>

        <!-- RECHTE SEITE: kompletter Chatbereich -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Chat Verlauf -->
            <ScrollViewer Grid.Row="0">
                <StackPanel x:Name="ChatPanel" Margin="10"/>
            </ScrollViewer>

            <!-- Eingabe Bereich -->
            <Grid Grid.Row="1" Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="110" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="110" />
                </Grid.ColumnDefinitions>

                <TextBox x:Name="InputTextBox"
                     Grid.Column="0"
                     Height="40"/>

                <Button x:Name="SendButton"
                    Grid.Column="2"
                    Content="Senden"
                    Height="40"
                    Click="SendButton_Click"/>

                <Button x:Name="LiveToggleButton"
                    Grid.Column="4"
                    Content="Live Start"
                    Height="40"
                    Click="LiveToggleButton_Click"/>
            </Grid>
        </Grid>
    </Grid>
</Window>
