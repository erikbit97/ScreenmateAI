<Window x:Class="ScreenmateAi.Anmelden"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Screenmate AI Login"
        Height="500"
        Width="900"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#111827">

    <Grid>

        <!-- Hintergrund -->
        <Border Background="#111827"/>

        <!-- Login Card -->
        <Border Width="420"
                Height="320"
                Background="#1F2937"
                CornerRadius="16"
                Padding="30"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">

            <StackPanel Margin="0,0,0,-7">

                <!-- Titel -->
                <TextBlock Text="Screenmate AI"
                           Foreground="White"
                           FontSize="28"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"/>

                <TextBlock Text="OpenAI API Verbindung"
                           Foreground="#9CA3AF"
                           FontSize="14"
                           Margin="0,8,0,30"
                           HorizontalAlignment="Center"/>

                <!-- API Label -->
                <TextBlock Text="OpenAI API Key"
                           Foreground="White"
                           FontWeight="SemiBold"
                           Margin="0,0,0,8"/>

                <!-- API Key Eingabe -->
                <TextBox x:Name="ApiKeyTextBox"
                         Height="38"
                         FontSize="14"
                         Padding="10"
                         Background="#374151"
                         Foreground="White"
                         BorderBrush="#4B5563"
                         CaretBrush="White"/>

                <!-- Hinweis -->
                <TextBlock Text="Dein API Key wird lokal gespeichert."
                           Foreground="#9CA3AF"
                           FontSize="12"
                           Margin="0,10,0,20"/>

                <!-- Buttons -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center">

                    <Button Content="OpenAI API Keys"
                            Width="150"
                            Height="40"
                            Margin="0,0,15,0"
                            Click="OpenApiPage_Click"
                            Background="#374151"
                            Foreground="White"
                            BorderBrush="#4B5563"/>

                    <Button Content="Anmelden"
                            Width="120"
                            Height="40"
                            Click="AnmeldeButton_Click"
                            Background="#10A37F"
                            Foreground="White"
                            BorderBrush="#10A37F"/>
                   
                </StackPanel>
                <TextBlock x:Name="ErrorTextBlock"
                    Text=""
                    Foreground="#F87171"
                    FontSize="12"
                    Margin="0,10,0,0"
                    TextWrapping="Wrap" Height="23"/>


            </StackPanel>

        </Border>
        
    </Grid>
    
</Window>
